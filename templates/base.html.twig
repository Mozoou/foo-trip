<!DOCTYPE html>
<html lang="en" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Foo Trip{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>✈️</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="h-full bg-slate-50 text-slate-800 flex flex-col min-h-screen">

        {# ── Navbar ── #}
        <nav class="bg-slate-900 shadow-lg">
            <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">
                    <a href="{{ path('app_home') }}" class="flex items-center gap-2 text-white font-bold text-xl hover:text-sky-400 transition-colors">
                        <span class="text-2xl">✈</span> Foo Trip
                    </a>
                    <div class="flex items-center gap-4">
                        <a href="{{ path('app_home') }}" class="text-slate-300 hover:text-white text-sm font-medium transition-colors">
                            Destinations
                        </a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_admin_destination_index') }}" class="text-slate-300 hover:text-white text-sm font-medium transition-colors">
                                Backoffice
                            </a>
                            <a href="{{ path('app_logout') }}" class="bg-slate-700 hover:bg-slate-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
                                Logout
                            </a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
                                Admin Login
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        {# ── Flash messages ── #}
        {% set flashes_success = app.flashes('success') %}
        {% set flashes_error   = app.flashes('error') %}
        {% if flashes_success or flashes_error %}
            <div class="max-w-6xl mx-auto w-full px-4 sm:px-6 lg:px-8 pt-4">
                {% for message in flashes_success %}
                    <div class="flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-lg mb-2 text-sm">
                        <span class="text-emerald-500">✓</span> {{ message }}
                    </div>
                {% endfor %}
                {% for message in flashes_error %}
                    <div class="flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-2 text-sm">
                        <span class="text-red-500">✕</span> {{ message }}
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {# ── Main content ── #}
        <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
            {% block body %}{% endblock %}
        </main>

        {# ── Footer ── #}
        <footer class="bg-slate-900 text-slate-400 text-sm text-center py-6 mt-auto">
            © {{ "now"|date("Y") }} Foo Trip — Honeymoon Destinations
        </footer>

    </body>
</html>
