{% extends 'base.html.twig' %}

{% block title %}Admin - Destinations{% endblock %}

{% block body %}
    <h1>Manage Destinations</h1>
    <a class="btn" href="{{ path('app_admin_destination_new') }}">+ New Destination</a>

    <table style="margin-top: 20px;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Price</th>
                <th>Duration</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for destination in destinations %}
                <tr>
                    <td>{{ destination.id }}</td>
                    <td>{{ destination.name }}</td>
                    <td>{{ destination.price }} €</td>
                    <td>{{ destination.duration }}</td>
                    <td>
                        <a class="btn btn-secondary" href="{{ path('app_destination_show', {id: destination.id}) }}">View</a>
                        <a class="btn" href="{{ path('app_admin_destination_edit', {id: destination.id}) }}">Edit</a>
                        <form method="post" action="{{ path('app_admin_destination_delete', {id: destination.id}) }}" style="display:inline" onsubmit="return confirm('Delete this destination?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ destination.id) }}">
                            <button class="btn" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">No destinations found. <a href="{{ path('app_admin_destination_new') }}">Create one</a>.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
