{% extends 'base.html.twig' %}

{% block title %}Edit {{ destination.name }} - Admin{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('app_admin_destination_index') }}" class="inline-flex items-center gap-1 text-slate-500 hover:text-sky-600 text-sm font-medium transition-colors">
            ← Back to list
        </a>
    </div>

    <div class="max-w-2xl">
        <h1 class="text-3xl font-bold text-slate-900 mb-2">Edit Destination</h1>
        <p class="text-slate-500 text-sm mb-8">{{ destination.name }}</p>

        <div class="bg-white rounded-2xl shadow-sm p-8">
            {% include 'admin/destination/_form.html.twig' with {submit_label: 'Save Changes'} %}
        </div>
    </div>
{% endblock %}
