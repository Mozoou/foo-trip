{% extends 'base.html.twig' %}

{% block title %}Edit {{ destination.name }} - Admin{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('app_admin_destination_index') }}" class="inline-flex items-center gap-1 text-slate-500 hover:text-sky-600 text-sm font-medium transition-colors">
            ← Back to list
        </a>
    </div>

    <div class="max-w-2xl">
        <h1 class="text-3xl font-bold text-slate-900 mb-2">Edit Destination</h1>
        <p class="text-slate-500 text-sm mb-8">{{ destination.name }}</p>

        <div class="bg-white rounded-2xl shadow-sm p-8">
            {% include 'admin/destination/_form.html.twig' %}
            <div class="pt-6 mt-6 border-t border-slate-100 flex items-center gap-4">
                <button form="{{ form.vars.id }}" type="submit"
                        class="bg-sky-500 hover:bg-sky-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">
                    Save Changes
                </button>
                <a href="{{ path('app_admin_destination_index') }}" class="text-slate-500 hover:text-slate-800 text-sm font-medium transition-colors">
                    Cancel
                </a>
            </div>
        </div>
    </div>
{% endblock %}
