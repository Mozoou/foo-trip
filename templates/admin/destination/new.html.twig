{% extends 'base.html.twig' %}

{% block title %}New Destination - Admin{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('app_admin_destination_index') }}" class="inline-flex items-center gap-1 text-slate-500 hover:text-sky-600 text-sm font-medium transition-colors">
            ← Back to list
        </a>
    </div>

    <div class="max-w-2xl">
        <h1 class="text-3xl font-bold text-slate-900 mb-8">New Destination</h1>

        <div class="bg-white rounded-2xl shadow-sm p-8">
            {% include 'admin/destination/_form.html.twig' %}
            <div class="pt-6 mt-6 border-t border-slate-100">
                <button form="{{ form.vars.id }}" type="submit"
                        class="bg-sky-500 hover:bg-sky-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">
                    Create Destination
                </button>
            </div>
        </div>
    </div>
{% endblock %}
