{{ form_start(form, {attr: {class: 'space-y-5'}}) }}

    {% for field in form %}
        {% if not field.rendered %}
            {% if 'hidden' in field.vars.block_prefixes %}
                {{ form_widget(field) }}
            {% else %}
                <div>
                    {{ form_label(field, null, {label_attr: {class: 'block text-sm font-semibold text-slate-700 mb-1.5'}}) }}
                    {{ form_widget(field, {attr: {class: 'w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition'}}) }}
                    {% if form_errors(field) %}
                        <p class="text-red-500 text-xs mt-1">{{ form_errors(field) }}</p>
                    {% endif %}
                </div>
            {% endif %}
        {% endif %}
    {% endfor %}

    <div class="pt-6 mt-2 border-t border-slate-100 flex items-center gap-4">
        <button type="submit"
                class="bg-sky-500 hover:bg-sky-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm cursor-pointer">
            {{ submit_label ?? 'Save' }}
        </button>
        <a href="{{ path('app_admin_destination_index') }}"
           class="text-slate-500 hover:text-slate-800 text-sm font-medium transition-colors">
            Cancel
        </a>
    </div>

{{ form_end(form) }}
