{% extends 'base.html.twig' %}

{% block title %}{{ destination.name }} - Foo Trip{% endblock %}

{% block body %}
    <a class="btn btn-secondary" href="{{ path('app_home') }}">&larr; Back to destinations</a>

    <div class="card" style="margin-top: 20px;">
        <img src="{{ destination.image }}" alt="{{ destination.name }}"
             style="width: 100%; max-height: 350px; object-fit: cover; border-radius: 6px;"
             onerror="this.src='https://placehold.co/800x350?text=No+Image'">

        <h1>{{ destination.name }}</h1>
        <p>{{ destination.description }}</p>

        <table style="width: auto; margin-top: 15px;">
            <tr>
                <th>Price</th>
                <td>{{ destination.price }} €</td>
            </tr>
            <tr>
                <th>Duration</th>
                <td>{{ destination.duration }}</td>
            </tr>
        </table>
    </div>
{% endblock %}
