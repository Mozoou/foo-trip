{% extends 'base.html.twig' %}

{% block title %}{{ destination.name }} - Foo Trip{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('app_home') }}" class="inline-flex items-center gap-1 text-slate-500 hover:text-sky-600 text-sm font-medium transition-colors">
            ← Back to destinations
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        {# ── Hero image ── #}
        <div class="relative h-80 sm:h-96">
            <img
                src="{{ destination.image }}"
                alt="{{ destination.name }}"
                class="w-full h-full object-cover"
                onerror="this.src='https://placehold.co/1200x500?text=No+Image'"
            >
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6 text-white">
                <h1 class="text-4xl font-bold drop-shadow-lg">{{ destination.name }}</h1>
            </div>
        </div>

        {# ── Details ── #}
        <div class="p-6 sm:p-10">
            <div class="flex flex-wrap gap-4 mb-8">
                <div class="flex items-center gap-2 bg-sky-50 text-sky-700 px-4 py-2 rounded-full text-sm font-semibold">
                    <span>💶</span> {{ destination.price }} €
                </div>
                <div class="flex items-center gap-2 bg-emerald-50 text-emerald-700 px-4 py-2 rounded-full text-sm font-semibold">
                    <span>📅</span> {{ destination.duration }}
                </div>
            </div>

            <h2 class="text-xl font-bold text-slate-800 mb-3">About this destination</h2>
            <p class="text-slate-600 leading-relaxed text-base max-w-3xl">{{ destination.description }}</p>

            <div class="mt-10 pt-6 border-t border-slate-100">
                <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 bg-sky-500 hover:bg-sky-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
                    ← Explore other destinations
                </a>
            </div>
        </div>
    </div>
{% endblock %}
